reduction_use <- "pca"
if (USE_HARMONY && !has_secs)
cat("  NOTA: USE_HARMONY=TRUE ma grid_section assente — uso PCA.\n")
}
# ── Clustering e UMAP finale (sul embedding corretto) ────────────────────
xen_sub <- FindNeighbors(xen_sub, reduction = reduction_use,
dims = seq_len(npcs_actual), verbose = FALSE)
xen_sub <- FindClusters(xen_sub, resolution = RESOLUTION, verbose = FALSE)
xen_sub <- RunUMAP(xen_sub,
reduction = reduction_use, dims = seq_len(npcs_actual),
min.dist = 0.3, spread = 1, verbose = FALSE)
# ── Plot diagnostico Harmony: UMAP prima vs dopo ──────────────────────────
if (USE_HARMONY && has_secs && "umap_raw" %in% names(xen_sub@reductions)) {
theme_umap_diag <- theme_void(base_size = 10) +
theme(plot.background = element_rect(fill = "white", color = NA),
plot.title      = element_text(face = "bold", size = 10),
plot.subtitle   = element_text(size = 8, color = "#555555"),
legend.text     = element_text(size = 7),
legend.key.size = unit(0.35, "cm"))
p_before <- DimPlot(xen_sub, reduction = "umap_raw",
group.by = "section", pt.size = 0.4) +
labs(title    = "Prima di Harmony",
subtitle = "Cluster separati = batch paziente") +
theme_umap_diag
p_after <- DimPlot(xen_sub, reduction = "umap",
group.by = "section", pt.size = 0.4) +
labs(title    = "Dopo Harmony",
subtitle = "Sezioni miste = batch corretto ✓") +
theme_umap_diag
p_hcheck <- (p_before | p_after) +
plot_annotation(
title    = paste0("Controllo batch effect — ", TARGET_TYPE),
subtitle = paste0("Colorato per sezione/paziente  |  ",
"Sinistra: PCA grezza  |  Destra: Harmony (", reduction_use, ")"),
theme    = theme(
plot.background = element_rect(fill = "white", color = NA),
plot.title      = element_text(face = "bold", size = 12),
plot.subtitle   = element_text(size = 9, color = "#444444")
)
)
ggsave(file.path(PLOT_DIR, "harmony_check.pdf"),
p_hcheck, width = 14, height = 6, bg = "white")
cat("Salvato: harmony_check.pdf\n")
}
# ── Nomina sub-cluster (Breast_cancer_1, Breast_cancer_2, …) ─────────────
n_sc     <- nlevels(xen_sub@meta.data$seurat_clusters)
sc_names <- paste0(safe_name, "_", seq_len(n_sc))
names(sc_names) <- as.character(seq(0L, n_sc - 1L))
# Assegnazione diretta a @meta.data per evitare il passaggio attraverso
# [[<-.Seurat → AddMetaData: xen_sub$col <- vector chiama AddMetaData, che
# controlla names(vector) %in% Cells(object). Il vettore ottenuto da
# sc_names[as.character(xen_sub$seurat_clusters)] ha come nomi i cluster-id
# ("0","1",...) non i barcode → zero overlap → errore.
# Con @meta.data$ si assegna direttamente al data.frame: i nomi vengono ignorati.
xen_sub@meta.data$subcluster <- factor(
sc_names[as.character(xen_sub@meta.data$seurat_clusters)],
levels = sc_names
)
cat(n_sc, "sub-cluster trovati:", paste(sc_names, collapse = ", "), "\n")
if (n_sc == 1L)
cat("  NOTA: 1 solo cluster. Prova ad aumentare RESOLUTION o N_PCS.\n")
# Trasferisci etichette al Seurat principale usando target_cells_global
# (nomi originali da xen, garantiti validi in xen@meta.data).
xen@meta.data[target_cells_global, sc_col] <- as.character(xen_sub@meta.data$subcluster)
sc_pal <- make_sc_palette(sc_names)
# ── Modalità PER_SECTION ──────────────────────────────────────────────────────
} else {
if (!has_secs)
stop("SUBCLUSTER_MODE='per_section' richiede la colonna grid_section.")
# In modalità per_section ogni chiamata è già su un solo paziente →
# nessun batch effect tra pazienti → Harmony non necessario.
if (USE_HARMONY)
cat("  NOTA: USE_HARMONY ignorato in modalità per_section",
"(ogni sezione è già un paziente singolo).\n")
cat("Sezioni da analizzare:", paste(secs, collapse = ", "), "\n\n")
sc_names_all <- character(0)
for (sec in secs) {
cells_s <- rownames(xen@meta.data)[
!is.na(xen$grid_section)        & xen$grid_section == sec &
!is.na(xen$cell_type_xenium_l1) & xen$cell_type_xenium_l1 == TARGET_TYPE
]
cat("  Sezione", sec, "—",
formatC(length(cells_s), big.mark = ",", format = "d"),
"cellule", TARGET_TYPE, "... ")
if (length(cells_s) < MIN_CELLS_SC) {
cat("SALTATA (< MIN_CELLS_SC =", MIN_CELLS_SC, ")\n")
per_sec_results[[sec]] <- list(done = FALSE, n = length(cells_s))
next
}
# Oggetto NON-spaziale: colnames == cells_s garantito
xen_s  <- CreateSeuratObject(counts = raw_counts[, cells_s], assay = "RNA")
npcs_s <- min(N_PCS, floor(length(cells_s) / 5L), nrow(xen_s) - 1L)
xen_s  <- run_sub_pipeline(xen_s, npcs_s, RESOLUTION)
n_sc_s   <- nlevels(xen_s@meta.data$seurat_clusters)
names_s  <- paste0(sec, "_", safe_name, "_", seq_len(n_sc_s))
names(names_s) <- as.character(seq(0L, n_sc_s - 1L))
# @meta.data$ directo evita [[<-.Seurat → AddMetaData (stesso bug del global mode)
xen_s@meta.data$subcluster <- factor(
names_s[as.character(xen_s@meta.data$seurat_clusters)],
levels = names_s
)
xen_s@meta.data$section    <- sec
# Marker per questa sezione
if (n_sc_s > 1L) {
Idents(xen_s) <- "subcluster"
mkrs <- tryCatch(
FindAllMarkers(xen_s, only.pos = TRUE,
min.pct = 0.2, logfc.threshold = 0.2,
test.use = "wilcox", verbose = FALSE),
error = function(e) NULL
)
} else {
mkrs <- NULL
}
# cells_s sono i nomi originali da xen → assegnazione diretta senza mismatch
xen@meta.data[cells_s, sc_col] <- as.character(xen_s$subcluster)
sc_names_all              <- c(sc_names_all, names_s)
xen_sub_list[[sec]]       <- xen_s
markers_per_sec[[sec]]    <- mkrs
per_sec_results[[sec]]    <- list(done = TRUE, n = length(cells_s),
n_sc = n_sc_s, names = names_s)
cat(n_sc_s, "sub-cluster\n")
}
sc_names <- sc_names_all
n_sc     <- length(sc_names)
sc_pal   <- make_sc_palette(sc_names)
# Oggetto "combinato" per DotPlot (solo per_section: merge gli xen_s)
if (length(xen_sub_list) >= 2L) {
xen_sub <- merge(xen_sub_list[[1]], y = xen_sub_list[-1],
add.cell.ids = names(xen_sub_list))
} else if (length(xen_sub_list) == 1L) {
xen_sub <- xen_sub_list[[1]]
} else {
xen_sub <- NULL
}
}
# ─── STEP 3: MARKER DIFFERENZIALI ─────────────────────────────────────────────
cat("\n=== STEP 3: Marker differenziali ===\n")
markers_all <- NULL
top_markers <- data.frame()
find_markers_global <- function(sobj, sc_names) {
if (is.null(sobj) || n_sc < 2L) return(NULL)
Idents(sobj) <- "subcluster"
tryCatch(
FindAllMarkers(sobj, only.pos = TRUE,
min.pct = 0.25, logfc.threshold = 0.25,
test.use = "wilcox", verbose = FALSE),
error = function(e) {
cat("ATTENZIONE: marker non calcolati:", conditionMessage(e), "\n")
NULL
}
)
}
if (SUBCLUSTER_MODE == "global") {
markers_all <- find_markers_global(xen_sub, sc_names)
} else {
# Combina i marker per-sezione in un unico data.frame
combined <- lapply(names(markers_per_sec), function(s) {
m <- markers_per_sec[[s]]
if (!is.null(m) && nrow(m) > 0) cbind(section = s, m) else NULL
})
combined <- Filter(Negate(is.null), combined)
if (length(combined) > 0) markers_all <- do.call(rbind, combined)
}
if (!is.null(markers_all) && nrow(markers_all) > 0) {
markers_all$cluster <- as.character(markers_all$cluster)
top_markers <- markers_all %>%
group_by(cluster) %>%
arrange(p_val_adj, desc(avg_log2FC)) %>%
slice_head(n = N_MARKERS) %>%
ungroup()
cat("Marker trovati:\n")
for (sc in sc_names) {
n_mk <- sum(markers_all$cluster == sc)
cat("  ", sc, ":", n_mk, "marker\n")
}
} else {
cat("Nessun marker significativo trovato (n_sc =", n_sc, ").\n")
}
# ─── STEP 4: TABELLA RIEPILOGO SEZIONI × SUB-CLUSTER ─────────────────────────
cat("\n=== STEP 4: Tabella riepilogo ===\n")
summary_counts <- NULL
summary_pct    <- NULL
if (has_secs && n_sc > 0L) {
md_t <- xen@meta.data[
!is.na(xen@meta.data[[sc_col]]) &
!is.na(xen@meta.data$grid_section) &
xen@meta.data$grid_section != "Noise",
]
ct <- table(Sezione    = md_t$grid_section,
SubCluster = md_t[[sc_col]])
summary_counts <- as.data.frame.matrix(ct)
summary_counts <- cbind(
Sezione  = rownames(summary_counts),
N_totale = rowSums(summary_counts),
summary_counts
)
rownames(summary_counts) <- NULL
# Aggiunge metadati clinici di sezione (se disponibili)
if (length(sec_meta_cols) > 0) {
smeta <- unique(md_t[, c("grid_section", sec_meta_cols), drop = FALSE])
colnames(smeta)[1] <- "Sezione"
summary_counts <- merge(summary_counts, smeta, by = "Sezione", all.x = TRUE)
}
# Tabella percentuali
summary_pct    <- summary_counts
sc_num_cols    <- sc_names[sc_names %in% colnames(summary_pct)]
for (sc in sc_num_cols)
summary_pct[[sc]] <- round(
100 * as.numeric(summary_counts[[sc]]) / as.numeric(summary_counts$N_totale), 1
)
cat("Riepilogo (conteggi):\n")
print(summary_counts[, c("Sezione", "N_totale", sc_num_cols)], row.names = FALSE)
}
# ─── STEP 5: VISUALIZZAZIONI ──────────────────────────────────────────────────
cat("\n=== STEP 5: Plot ===\n")
# ── 5A: UMAP (solo global, richiede dimensioni ridotte) ───────────────────────
if (SUBCLUSTER_MODE == "global" && !is.null(xen_sub) &&
"umap" %in% names(xen_sub@reductions)) {
p_sc <- DimPlot(xen_sub, group.by = "subcluster",
cols = sc_pal, pt.size = 0.6, label = TRUE,
label.size = 3.5, repel = TRUE) +
NoLegend() +
labs(title    = paste0("UMAP — Sub-cluster: ", TARGET_TYPE),
subtitle = paste0("risoluzione=", RESOLUTION,
"  |  N_PCS=", N_PCS,
"  |  n=",
formatC(ncol(xen_sub), big.mark=",", format="d"))) +
theme_void(base_size = 10) +
theme(plot.background = element_rect(fill = "white", color = NA),
plot.title      = element_text(face = "bold", size = 11))
p_sec <- if (has_secs && "section" %in% colnames(xen_sub@meta.data)) {
DimPlot(xen_sub, group.by = "section", pt.size = 0.6) +
labs(title = "UMAP — Sezione di origine") +
theme_void(base_size = 10) +
theme(plot.background = element_rect(fill = "white", color = NA),
plot.title      = element_text(face = "bold", size = 11))
} else NULL
p_umap <- if (!is.null(p_sec)) (p_sc | p_sec) else p_sc
ggsave(file.path(PLOT_DIR, "umap_subclusters.pdf"),
p_umap, width = if (!is.null(p_sec)) 14 else 7,
height = 6, bg = "white")
cat("Salvato: umap_subclusters.pdf\n")
}
# ── 5B: DotPlot top marker ────────────────────────────────────────────────────
if (!is.null(markers_all) && nrow(top_markers) > 0 && !is.null(xen_sub)) {
top_genes <- unique(top_markers$gene)
if (length(top_genes) > 50L) top_genes <- top_genes[seq_len(50L)]
Idents(xen_sub) <- "subcluster"
p_dot <- tryCatch({
DotPlot(xen_sub, features = top_genes,
cols = c("#F3F4F6", "#E63946"), dot.scale = 5,
group.by = "subcluster") +
coord_flip() +
labs(title    = paste0("Top ", N_MARKERS, " marker per sub-cluster"),
subtitle = TARGET_TYPE) +
theme_minimal(base_size = 9) +
theme(
axis.text.x     = element_text(angle = 45, hjust = 1, size = 8),
axis.text.y     = element_text(size  = 8),
axis.title      = element_blank(),
plot.background = element_rect(fill = "white", color = NA),
plot.title      = element_text(face = "bold", size = 11)
)
}, error = function(e) {
cat("  DotPlot non disponibile:", conditionMessage(e), "\n")
NULL
})
if (!is.null(p_dot)) {
h_dot <- max(5, length(top_genes) * 0.27 + 2.5)
ggsave(file.path(PLOT_DIR, "dotplot_markers.pdf"),
p_dot, width = max(6, n_sc * 1.2 + 3), height = h_dot, bg = "white")
cat("Salvato: dotplot_markers.pdf\n")
}
}
# ── 5C: Spatial overview (tutte le sezioni) ───────────────────────────────────
if (!is.null(coords_all)) {
coords_all[[sc_col]] <- xen@meta.data[coords_all$cell, sc_col]
df_fg_ov <- coords_all[!is.na(coords_all[[sc_col]]), ]
df_bg_ov <- coords_all[ is.na(coords_all[[sc_col]]), ]
# Subsample sfondo per performance
if (nrow(df_bg_ov) > 80000L)
df_bg_ov <- df_bg_ov[sample.int(nrow(df_bg_ov), 80000L), ]
# Aggiunge distribuzione per sub-cluster nel subtitle
sc_dist <- table(df_fg_ov[[sc_col]])
sc_dist_str <- paste(
paste0(names(sc_dist), " (n=",
formatC(as.integer(sc_dist), big.mark=",", format="d"), ")"),
collapse = "  ·  "
)
p_ov <- spatial_sc_plot(
df_bg      = df_bg_ov,
df_fg      = df_fg_ov,
color_col  = sc_col,
pal        = sc_pal,
title_str  = paste0("Sub-cluster ", TARGET_TYPE, " — vetrino completo"),
subtitle_str = sc_dist_str
)
ggsave(file.path(PLOT_DIR, "spatial_overview.pdf"),
p_ov, width = 14, height = 10, bg = "white")
cat("Salvato: spatial_overview.pdf\n")
# ── 5D: PDF per sezione ─────────────────────────────────────────────────────
if (has_secs && length(secs) > 0L) {
sec_dir <- file.path(PLOT_DIR, "per_sezione")
dir.create(sec_dir, showWarnings = FALSE)
for (sec in secs) {
df_sec_all <- coords_all[!is.na(coords_all$section) &
coords_all$section == sec, ]
df_sec_fg  <- df_sec_all[!is.na(df_sec_all[[sc_col]]), ]
n_fg       <- nrow(df_sec_fg)
if (n_fg < 5L) {
cat("  Sezione", sec, "— saltata (< 5 cellule target)\n")
next
}
# Distribuzione sub-cluster in questa sezione
sc_dist_sec <- sort(table(df_sec_fg[[sc_col]]), decreasing = TRUE)
sc_dist_sec_str <- paste(
paste0(names(sc_dist_sec), "=",
formatC(as.integer(sc_dist_sec), big.mark=",", format="d")),
collapse = "  |  "
)
# Metadati clinici per il subtitle
sec_meta_str <- ""
if (length(sec_meta_cols) > 0) {
meta_r <- unique(xen@meta.data[
!is.na(xen@meta.data$grid_section) &
xen@meta.data$grid_section == sec,
sec_meta_cols, drop = FALSE
])
if (nrow(meta_r) > 0) {
mc_names     <- gsub("^section_", "", sec_meta_cols)
sec_meta_str <- paste(
paste0(mc_names, "=", as.character(meta_r[1L, ])),
collapse = "  |  "
)
}
}
subtitle_sec <- paste0(
formatC(n_fg, big.mark=",", format="d"),
" cellule ", TARGET_TYPE,
if (nchar(sec_meta_str) > 0) paste0("  ·  ", sec_meta_str) else "",
"\n", sc_dist_sec_str
)
p_sec_sp <- spatial_sc_plot(
df_bg      = df_sec_all,
df_fg      = df_sec_fg,
color_col  = sc_col,
pal        = sc_pal,
title_str  = paste0("Sezione ", sec,
"  —  Sub-cluster ", TARGET_TYPE),
subtitle_str = subtitle_sec
)
# Aggiunge barra di composizione sotto la mappa
ct_df <- data.frame(
sc  = names(sc_dist_sec),
n   = as.integer(sc_dist_sec),
pct = round(100 * as.integer(sc_dist_sec) / n_fg, 1)
)
ct_df$sc <- factor(ct_df$sc, levels = names(sc_dist_sec))
p_bar <- ggplot(ct_df, aes(x = "", y = pct, fill = sc)) +
geom_col(width = 0.55) +
scale_fill_manual(values = sc_pal[names(sc_dist_sec)],
name = "Sub-cluster") +
scale_y_continuous(labels = function(x) paste0(x, "%"),
expand = expansion(mult = c(0, 0.02))) +
coord_flip() +
labs(title = "Composizione sezione") +
theme_minimal(base_size = 9) +
theme(
axis.title      = element_blank(),
axis.text.y     = element_blank(),
axis.text.x     = element_text(size = 8),
panel.grid.major.y = element_blank(),
panel.background   = element_rect(fill = "white", color = NA),
plot.background    = element_rect(fill = "white", color = NA),
plot.title         = element_text(face = "bold", size = 9),
legend.position    = "none"
)
p_combined_sec <- p_sec_sp / p_bar +
plot_layout(heights = c(9, 1)) +
plot_annotation(
theme = theme(plot.background = element_rect(fill = "white", color = NA))
)
out_sec <- file.path(sec_dir, paste0("spatial_", sec, ".pdf"))
ggsave(out_sec, p_combined_sec, width = 11, height = 10, bg = "white")
cat("  Salvato: spatial_", sec, ".pdf\n", sep = "")
}
}
}
# ─── STEP 6: SALVATAGGIO EXCEL E RDS ─────────────────────────────────────────
cat("\n=== STEP 6: Salvataggio ===\n")
# ── Excel ─────────────────────────────────────────────────────────────────────
wb          <- createWorkbook()
hdr_style   <- createStyle(fontColour = "#FFFFFF", fgFill = "#1D3557",
halign = "CENTER", textDecoration = "Bold",
border = "Bottom", borderColour = "#AAAAAA")
num_style   <- createStyle(numFmt = "0.0", halign = "RIGHT")
pct_style   <- createStyle(numFmt = "0.0", halign = "RIGHT")
# Foglio 1 — Riepilogo conteggi
if (!is.null(summary_counts)) {
addWorksheet(wb, "Riepilogo_N")
writeData(wb, "Riepilogo_N", summary_counts, headerStyle = hdr_style)
setColWidths(wb, "Riepilogo_N",
cols = seq_len(ncol(summary_counts)), widths = "auto")
# Zebra striping (guard: seq() fallisce se summary_counts è vuoto)
if (nrow(summary_counts) > 0)
for (r in seq(2, nrow(summary_counts) + 1, by = 2))
addStyle(wb, "Riepilogo_N",
createStyle(fgFill = "#F0F4F8"),
rows = r, cols = seq_len(ncol(summary_counts)), gridExpand = TRUE)
}
# Foglio 2 — Riepilogo percentuali
if (!is.null(summary_pct)) {
addWorksheet(wb, "Riepilogo_pct")
writeData(wb, "Riepilogo_pct", summary_pct, headerStyle = hdr_style)
setColWidths(wb, "Riepilogo_pct",
cols = seq_len(ncol(summary_pct)), widths = "auto")
}
# Foglio per ogni sub-cluster — top marker
if (!is.null(markers_all) && nrow(markers_all) > 0) {
marker_cols_keep <- intersect(
c("gene", "avg_log2FC", "pct.1", "pct.2", "p_val_adj", "cluster"),
colnames(markers_all)
)
if (SUBCLUSTER_MODE == "per_section" && "section" %in% colnames(markers_all))
marker_cols_keep <- c("section", marker_cols_keep)
for (sc in sc_names) {
mk <- markers_all[markers_all$cluster == sc, marker_cols_keep, drop = FALSE]
if (nrow(mk) == 0L) next
mk <- mk[order(mk$p_val_adj, -mk$avg_log2FC), ]
sheet_nm <- substr(paste0("Markers_", sc), 1L, 31L)
addWorksheet(wb, sheet_nm)
writeData(wb, sheet_nm, mk, headerStyle = hdr_style)
setColWidths(wb, sheet_nm,
cols = seq_len(ncol(mk)), widths = "auto")
# Formattazione condizionale logFC
lfc_col <- which(colnames(mk) == "avg_log2FC")
if (length(lfc_col) > 0L && nrow(mk) > 0L)
conditionalFormatting(wb, sheet_nm,
cols = lfc_col,
rows = seq(2L, nrow(mk) + 1L),
style = c("#FFFFFF", "#F4A261"),
type = "colourScale")
# p_val_adj < 0.05 in grassetto
padj_col <- which(colnames(mk) == "p_val_adj")
if (length(padj_col) > 0L) {
sig_rows <- which(mk$p_val_adj < 0.05) + 1L
if (length(sig_rows) > 0L)
addStyle(wb, sheet_nm,
createStyle(textDecoration = "Bold"),
rows = sig_rows, cols = padj_col, stack = TRUE)
}
}
}
excel_out <- file.path(PLOT_DIR,
paste0("subcluster_", safe_name, "_results.xlsx"))
saveWorkbook(wb, excel_out, overwrite = TRUE)
cat("Excel salvato:", basename(excel_out), "\n")
# ── RDS aggiornato ────────────────────────────────────────────────────────────
rds_out <- file.path(OUTPUT_DIR,
glue("{stringa_identificative}_annotated.rds"))
saveRDS(xen, rds_out)
cat("RDS aggiornato:", basename(rds_out), "\n")
cat("Nuova colonna aggiunta:", sc_col, "\n")
# ─── RIEPILOGO FINALE ─────────────────────────────────────────────────────────
cat("\n=== STEP 3 COMPLETATO ===\n")
cat("Target:    ", TARGET_TYPE, "\n")
cat("Modalità:  ", SUBCLUSTER_MODE, "\n")
cat("Sub-cluster trovati:", n_sc, "\n")
if (n_sc > 0) cat("  ", paste(sc_names, collapse=", "), "\n")
cat("\nFile prodotti in:", PLOT_DIR, "\n")
cat("  pca_elbow.pdf\n")
if (USE_HARMONY && SUBCLUSTER_MODE == "global")
cat("  harmony_check.pdf        ← controlla se il batch è stato corretto\n")
cat("  umap_subclusters.pdf\n")
cat("  dotplot_markers.pdf\n")
cat("  spatial_overview.pdf\n")
cat("  per_sezione/spatial_<SEZIONE>.pdf\n")
cat("  subcluster_", safe_name, "_results.xlsx\n", sep="")
runApp('/Volumes/Elendil/Xenium_breast_2025/xenium_explorer_app')
rm(list=ls())
xen <- readRDS("path/al/tuo/file_annotated.rds")
xen <- readRDS("/Volumes/Elendil/Xenium_breast_2025/0038009_Turdo1_Region1/0038009_Turdo1_Region1_annotated.rds")
cat("Geni totali:", nrow(xen), "\n")
print(rownames(xen))
setwd("~/Documents/Projects/Open/CardAnalysis/AnalysisCard_Claude")
runApp()
shiny::runApp()
runApp()
runApp()
runApp()
runApp()
runApp()
runApp()
runApp()
runApp()
runApp()
runApp()
runApp()
